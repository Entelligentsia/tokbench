LEANCTX_374_TGZ_SHA256=878dff4b243f7022bf27485ae2808a160390c30286502859305e658aad173b51  # lean-ctx-x86_64-unknown-linux-gnu.tar.gz (v3.7.4 release asset)
PI_LEANCTX_EXT_PIN_A1=3.7.4   # npm exact pin
TOKBENCH_ARM_A1M_11=tokbench-arm-a1m:1.1  # 276576ce0a27 — REPLICATION ARM for a1m runs

