TOKBENCH_BASE_01_IMAGE_ID=sha256:d61691567b0a65c180682a75d5bd992e2d10676cd02f7f0b3d560e0a4f9fe2f4  # tokbench-base:0.1 (Dockerfile-built)
TOKBENCH_BASE_02_IMAGE_ID=sha256:a8d6cbf6faa1519fa4e5189670717b675335367d856fe417169c00b8406f7a29  # tokbench-base:0.2 (= 0.1 + interactive setup layer, committed 2026-06-05)
TOKBENCH_BASE_03_IMAGE_ID=sha256:b9820113529629d63d01cc781d57eceb9b7b886a793d70baba5d6dcb87b57171  # tokbench-base:0.3 DEPRECATED (host-grafted .forge scaffolding hotfix; superseded by 0.4)
TOKBENCH_BASE_IMAGE_ID=sha256:2fb8158054afdf8a8336c3c8899f1919b59ed9d66d2e10d82c991037c4c4e048  # tokbench-base:0.4 CANONICAL (= 0.2 + in-container /forge:init, committed 2026-06-05)

# 0.4 scaffolding provenance: /forge:init run INSIDE the container (forgecli 1.0.21,
# ollama-cloud models) — .forge/config.json, generation-manifest.json, personas/,
# workflows/, schemas/, skills/, templates/. Survives reset.sh (verified).
# forge-project.tgz (host-grafted path) retained for Dockerfile rebuilds only:
FORGE_PROJECT_TGZ_SHA256=eacc371912052783d7374dbff2ee2868c3a562257a5bfde480cacab6d035bd03

# ⚠ tokbench-base:0.2+ CONTAINS CREDENTIALS (~/.pi/agent/auth.json: ollama-cloud).
# ⚠ NEVER push this image to any registry. Local experiment use only.

# setup layer contents (docker commit of container tokbench-setup; from docker diff + bash history):
#   - standalone pi via https://pi.dev/install.sh -> ~/.local/bin/pi
#   - pi install npm:pi-ollama-cloud (provider extension)
#   - ollama-cloud auth -> ~/.pi/agent/auth.json
#   - ~/.pi/agent/settings.json: defaultProvider=ollama-cloud, defaultModel=glm-5.1, theme=forge-mono
#   - ~/.pi/forge-cli/config.json: persona-model map (see TOKBENCH_MODEL_* below)
PI_OLLAMA_CLOUD_EXT_VERSION=^0.5.0

# harness (installed via curl -fsSL https://4ge.sh | sh at build time)
FORGECLI_VERSION=1.0.21
FORGE_PLUGIN_VERSION=1.2.17
PI_RUNTIME_VERSION=0.78.0-forge.1

# testbench (shipped as git bundle — local repo is 2 commits ahead of origin)
TESTBENCH_HEAD_SHA=c239fbf2dcd9275e745a10b19d93935263b3e485
CARTOGRAPHER_BASELINE_TAG_SHA=a69aba0906baa0dcffd263abfc8efc2337482ca4
TESTBENCH_BUNDLE_SHA256=3a5482f91a3ac417c80a2fe3e75c94cc25107f27d7fc275b9462f2ad4bafed0c

# .forge/tools — host's live toolset (produced the golden snapshot + S01 baseline;
# differs from npm payload: has lib/validate.cjs, different store-cli.cjs)
FORGE_TOOLS_TGZ_SHA256=7081290f8bea17acf66330c7b9e0a5d65645979cef47d238772875ebe3c1a35c

# arm products — pinned when arm images are built
LEANCTX_VERSION=3.7.3                   # binary via repo install.sh --download
PI_LEANCTX_EXT_VERSION=^3.7.3           # pi install npm:pi-lean-ctx
TOKBENCH_ARM_A1_02_IMAGE_ID=sha256:b1595fb403501778e47d0fbb9f2f3c481c25c3f6d70754c786b898d58c9ea628  # tokbench-arm-a1:0.2 (ran a1-T-fix-r1)
TOKBENCH_ARM_A1_IMAGE_ID=tokbench-arm-a1:0.3   # e5069db3b5e0 — + fixed harvest (transcript engage-check, XDG lean-ctx paths, gain --deep snapshot)
TOKBENCH_ARM_A1M_01_IMAGE_ID=tokbench-arm-a1m:0.1 # DEAD-END: env alone insufficient — init-written ~/.pi/agent/mcp.json makes extension defer to nonexistent pi MCP adapter
TOKBENCH_ARM_A1M_IMAGE_ID=tokbench-arm-a1m:0.2 # A1 + LEAN_CTX_PI_ENABLE_MCP=1 + mcp.json removed (build + per-reset in arm-setup) -> embedded bridge engages
# a1 notes: lean-ctx init rewrites AGENTS.md (tracked) + adds LEAN-CTX.md (untracked);
# reset.sh wipes both -> arm-setup.sh hook re-applies after every reset (baked in a1 image)
# a1 run-1 finding: pi-lean-ctx DEFAULT runs one-shot CLI subprocesses (MCP bridge opt-in,
# off) -> no session cache, no ~13-tok re-reads; ctx_read payloads measured LARGER than
# source files (+0.4%..+21.6%); adoption 46% reads / 11% shell; net +59% input, 3x time
RTK_VERSION=0.42.2                      # installed via repo install.sh (latest release at build); >= 0.23.0 pi guard OK
TOKBENCH_ARM_A3_IMAGE_ID=tokbench-arm-a3:0.1  # sha256:7a7b57ff0dce — rtk + pi ext + arm-setup re-init hook
HEADROOM_IMAGE_DIGEST=ghcr.io/chopratejas/headroom@sha256:1f4f12b4e13da3cae33cafeb2a8f4017a2b8be63566538e5fc2b8d1e45a83ee0  # proxy v0.23.0
TOKBENCH_ARM_A2_IMAGE_ID=tokbench-arm-a2:0.1  # runner = base 0.4 + scripts; interception via OLLAMA_API_BASE -> sidecar (compose.yml)

# model split — DECIDED (design open item #2 closed): tiered glm map, baked into
# base 0.2 -> identical across all arms by construction (ollama-cloud provider)
TOKBENCH_MODEL_ARCHITECT=glm-5.1
TOKBENCH_MODEL_SUPERVISOR=glm-5.1
TOKBENCH_MODEL_ENGINEER=glm-4.7
TOKBENCH_MODEL_BUG_FIXER=glm-4.7
TOKBENCH_MODEL_QA_ENGINEER=glm-4.7
TOKBENCH_MODEL_PRODUCT_MANAGER=glm-4.7
TOKBENCH_MODEL_COLLATOR=glm-4.6
TOKBENCH_MODEL_LIBRARIAN=glm-4.6
TOKBENCH_MODEL_ORCHESTRATOR=glm-4.6

# transcript locations — CONFIRMED (design open item #4 closed):
#   ~/.pi/agent/sessions/<project-path>/*.jsonl  +  cartographer/.forge/transcripts/
# harvest.sh copies both parents already

# ── PUBLICATION BASE (reproducible, no credentials — built 2026-06-05) ──
TOKBENCH_BASE_10_IMAGE_ID=sha256:f79d752d66dd  # tokbench-base:1.0
FORGE_SCAFFOLD_10_SHA256=055a1aeb5822667e42642ccdfe95dc9e935967aa837b141cd4bcf87c0db343c1  # .forge scaffolding artifact (provenance: /forge:init on 0.4)
PI_OLLAMA_CLOUD_PIN=0.5.0  # exact, npm --legacy-peer-deps (peers = forge's vendored pi)
# auth: runtime -e OLLAMA_API_KEY only. base:1.0 fixes forge tools package.json at image level.

# ── publication arm images (1.0 generation, FROM base:1.0, all credential-free) ──
