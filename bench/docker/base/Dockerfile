# tokbench-base:1.0 — REPRODUCIBLE base for the publication rep runs.
# No interactive layers, no baked credentials. Auth is runtime-injected:
#   docker run -e OLLAMA_API_KEY=...  (provider declares apiKey: "OLLAMA_API_KEY")
# Third-party rebuild requires only this directory + network.
#
# Provenance of shipped artifacts (all extracted from the pilot base 0.4):
#   config/pi-agent-settings.json   pi defaults: provider=ollama-cloud, model=glm-5.1
#   config/forge-cli-config.json    persona->model map (glm-5.1/4.7/4.6 tiers)
#   config/pi-npm-package.json      pins pi-ollama-cloud@0.5.0 exact (no pi CLI needed)
#   forge-scaffold-1.0.tgz          .forge/ scaffolding generated by /forge:init
#                                   (forgecli 1.0.21, glm models, 2026-06-05) — published
#                                   verbatim so pilot and rep runs share identical
#                                   scaffolding; regeneration procedure documented in notes.
#   testbench.bundle                git bundle of forge-testbench @ c239fbf (all refs+tags)

FROM node@sha256:242549cd46785b480c832479a730f4f2a20865d61ea2e404fdb2a5c3d3b73ecf

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates tar jq ripgrep procps python3 \
 && rm -rf /var/lib/apt/lists/*

# ── 4ge harness, version-pinned via npm (no curl|sh, no "latest") ─────────────
RUN npm install -g @entelligentsia/forgecli@1.0.21 && forge --version

RUN useradd -m bench
USER bench
WORKDIR /home/bench
RUN git config --global user.name "Tokbench Runner" \
 && git config --global user.email "tokbench@bench.local" \
 && git config --global init.defaultBranch main

# ── testbench from pinned git bundle ──────────────────────────────────────────
COPY --chown=bench:bench testbench.bundle /tmp/testbench.bundle
RUN git clone /tmp/testbench.bundle /home/bench/forge-testbench \
 && cd /home/bench/forge-testbench && git checkout main \
 && rm /tmp/testbench.bundle \
 && cd cartographer && npm ci

# ── pi agent config + ollama-cloud provider extension (pure npm, exact-pinned) ─
# (--legacy-peer-deps: the extension's peer deps are provided at runtime by
#  forge's vendored pi runtime, intentionally not installed here)
COPY --chown=bench:bench config/pi-agent-settings.json /home/bench/.pi/agent/settings.json
COPY --chown=bench:bench config/forge-cli-config.json  /home/bench/.pi/forge-cli/config.json
COPY --chown=bench:bench config/pi-npm-package.json    /home/bench/.pi/agent/npm/package.json
RUN cd /home/bench/.pi/agent/npm && npm install --legacy-peer-deps --no-audit --no-fund

# ── forge project scaffolding (pinned artifact; see provenance header) ────────
COPY --chown=bench:bench forge-scaffold-1.0.tgz /tmp/scaffold.tgz
RUN mkdir -p /home/bench/forge-testbench/cartographer/.forge \
 && cd /home/bench/forge-testbench/cartographer/.forge \
 && tar -xzf /tmp/scaffold.tgz && rm /tmp/scaffold.tgz \
 && echo '{ "type": "commonjs" }' > tools/package.json
 # ^ fixes forge-cli 1.0.21 bug: init drops tools/package.json, breaking
 #   .forge/tools/*.cjs (lib/result.js is CJS) under ESM projects

# ── build-time gate: golden restore must verify PRISTINE ─────────────────────
RUN cd /home/bench/forge-testbench && ./testbench/reset.sh cartographer

COPY --chown=bench:bench --chmod=755 run-task.sh harvest.sh /usr/local/bin/

ENV TERM=xterm-256color
WORKDIR /home/bench/forge-testbench/cartographer
ENTRYPOINT ["/usr/local/bin/run-task.sh"]
